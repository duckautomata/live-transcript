# Supply-chain hardening. https://docs.npmjs.com/cli/v11/using-npm/config

# Block lifecycle scripts (postinstall, preinstall, etc). Defends against
# worms that propagate via install scripts (e.g. Shai-Hulud, Sept/Nov 2025).
# For packages that legitimately need scripts, run them explicitly:
#   npx playwright install chromium
#   npm rebuild <pkg>
ignore-scripts=true

# Only install package versions published more than N days ago. Gives the
# ecosystem time to detect and unpublish malicious releases before we pull
# them. Requires npm >= 11.10.0. Unit is days.
min-release-age=7
