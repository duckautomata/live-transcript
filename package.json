{
    "name": "live-transcript",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "format": "oxfmt .",
        "format:check": "oxfmt --check .",
        "lint": "oxlint .",
        "lint:fix": "oxlint --fix .",
        "test": "vitest run",
        "test:ci": "vitest run --reporter=junit --outputFile=junit.xml",
        "test:generate-mocks": "node tests/mocks/generate-snapshot.mjs && node tests/mocks/generate-consts.js",
        "test:mock": "playwright test --config=playwright.mock.config.js",
        "test:e2e": "playwright test"
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@fontsource/roboto": "^5.2.10",
        "@mui/icons-material": "^7.3.9",
        "@mui/material": "^7.3.9",
        "@mui/x-charts": "^8.28.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-h5-audio-player": "^3.10.2",
        "react-router-dom": "^7.13.2",
        "react-use-websocket": "^4.13.0",
        "react-virtuoso": "^4.18.3",
        "wavesurfer.js": "^7.12.5",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "esbuild": "^0.27.4",
        "oxfmt": "^0.42.0",
        "oxlint": "^1.57.0",
        "playwright": "^1.58.2",
        "vite": "^8.0.5",
        "vitest": "^4.1.2",
        "wrangler": "^4.78.0"
    }
}
